# Xcode — the .xcodeproj is generated by XcodeGen (project.yml is authoritative).
# Do NOT commit it. After cloning, run `xcodegen generate` before opening/building.
*.xcodeproj/
DerivedData/
build/

# macOS
.DS_Store
*.swp
*~

# Test Files (large image collections — not for version control)
Test Files/

# API keys
*.env

# Android / Gradle
.gradle/
local.properties
*.apk
*.iml
.idea/
captures/

# Test outputs (generated)
Test Outputs/

# Xcode user state (also under the nested project dir)
**/xcuserdata/
*.xcuserstate

# Transient maintenance/resume state (session working files; incl. test-results/)
.maintenance/
